{
    "name": "dagasmart/auditing",
    "description": "自动审计增删改模型行为事件 Eloquent models in Laravel",
    "keywords": [
        "auditing",
        "eloquent",
        "history",
        "log",
        "logging",
        "Laravel",
        "record"
    ],
    "homepage": "",
    "type": "package",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/dagasmart/auditing/issues",
        "source": "https://github.com/dagasmart/auditing"
    },
    "authors": [
        {
            "name": "dagasmart",
            "email": "dagasmart@qq.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.5.1",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "DagaSmart\\Auditing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DagaSmart\\Auditing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "v14-dev"
        },
        "laravel": {
            "providers": [
                "DagaSmart\\Auditing\\AuditingServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "composer require --dev laravel/pint --quiet && pint --config .pint.json && composer remove --dev laravel/pint --no-update",
        "analyse": "composer require --dev larastan/larastan --quiet && phpstan analyse && composer remove --dev larastan/larastan --no-update"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
